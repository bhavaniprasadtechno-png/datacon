# Same primary Postgres as the api service's ../api/.env — the ai service
# doesn't run migrations, it only reads seeded business-metrics tables.
DATABASE_URL="postgresql://postgres:password@localhost:5432/datacon"

CHROMA_URL="http://localhost:8001"
CHROMA_PERSIST_DIR="./.chroma"

# Optional: set to enable real LLM responses instead of the offline
# fallback. LLM_MODEL is a "provider/model" string.
TOGETHER_API_KEY="tgp_v1_xLYcoMZu7p_QqVoI9oYKqXUuDkIBbwKz2I2BU7TCV8E"
LLM_MODEL="Qwen/Qwen3.7-Plus"

# Must match INTERNAL_AUTH_TOKEN in ../api/.env exactly (api's shared secret
# for calling this service's /internal/* routes).
INTERNAL_AUTH_TOKEN="dev-internal-token"

# Local dev only: port the FastAPI dev server binds to (read by
# ../scripts/dev-ai.js). Change this if 8000 is unavailable on your
# machine — must match AI_SERVICE_URL in ../api/.env.
AI_DEV_PORT=8000
